@using BlazorCanvas.Geometry

@switch (Type)
{
    case FigureType.Line:
        <line x1="@X" y1="@Y" x2="@_lineX2" y2="@_lineY2" stroke="@StrokeColor" stroke-width="2" stroke-opacity="@OpacityValue" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
        break;
    case FigureType.Rectangle:
        <rect x="@X" y="@Y" width="@_width" height="@_height" fill="#FFFFFF" stroke="@StrokeColor" stroke-width="2" fill-opacity="@OpacityValue" stroke-opacity="@OpacityValue" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
        break;
    case FigureType.Circle:
        <circle cx="@X" cy="@Y" r="@_radius" fill="#FFFFFF" stroke="@StrokeColor" stroke-width="2" fill-opacity="@OpacityValue" stroke-opacity="@OpacityValue" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
        break;
    case FigureType.Triangle:
        <polygon points="@_trianglePoints" fill="#FFFFFF" stroke="@StrokeColor" stroke-width="2" fill-opacity="@OpacityValue" stroke-opacity="@OpacityValue" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
        break;
}

@code {
    // Renders one figure — or one live draw preview — as bare SVG child elements. Never emits a
    // nested SVG root element of its own: that would establish a new coordinate system and break
    // the 1:1 page-to-canvas mapping the whole phase rests on (D-18). The parent SVG element is
    // supplied by Home.razor.
    //
    // Since D-59 a figure is an anchor (X, Y) plus geometry JSON, not a bounding box: a circle is
    // no longer stored as an inscribed square that must be decoded through CircleEncoding — it is
    // a centre anchor plus {r} directly.

    [Parameter, EditorRequired]
    public FigureType Type { get; set; }

    [Parameter, EditorRequired]
    public int X { get; set; }

    [Parameter, EditorRequired]
    public int Y { get; set; }

    [Parameter, EditorRequired]
    public string Geometry { get; set; } = string.Empty;

    [Parameter]
    public bool Preview { get; set; }

    [Parameter]
    public bool Selectable { get; set; }

    [Parameter]
    public EventCallback<PointerEventArgs> OnPointerDown { get; set; }

    // Preview mode renders at stroke-opacity="0.7" fill-opacity="0.7" (03-UI-SPEC) so it reads as
    // "not yet real" without inventing a new colour, which D-14 forbids. A committed figure (the
    // default) renders fully opaque.
    private string OpacityValue => Preview ? "0.7" : "1";

    private string StrokeColor => "#000000";

    private int _lineX2;
    private int _lineY2;
    private int _width;
    private int _height;
    private int _radius;
    private string _trianglePoints = string.Empty;

    // Decoded once per parameter change through the shared ShapeRender helper (D-59), never from a
    // markup expression — each attribute read would otherwise deserialise the geometry JSON again.
    // Sharing ShapeRender with SelectionTrace is what guarantees a trace can never disagree with
    // the figure it traces.
    protected override void OnParametersSet()
    {
        switch (Type)
        {
            case FigureType.Line:
                var (dx, dy) = ShapeRender.LineDelta(Geometry);
                _lineX2 = X + dx;
                _lineY2 = Y + dy;
                break;
            case FigureType.Rectangle:
                (_width, _height) = ShapeRender.Size(Geometry);
                break;
            case FigureType.Circle:
                _radius = ShapeRender.Radius(Geometry);
                break;
            case FigureType.Triangle:
                (_width, _height) = ShapeRender.Size(Geometry);
                _trianglePoints = ShapeRender.TrianglePoints(X, Y, _width, _height);
                break;
        }
    }

    private Task HandlePointerDown(PointerEventArgs e) =>
        Selectable ? OnPointerDown.InvokeAsync(e) : Task.CompletedTask;
}
