@using System.Globalization
@using BlazorCanvas.Data.V11
@using BlazorCanvas.Shapes

@if (Geometry is not null)
{
    <g transform="@Transform">
        @switch (Geometry)
        {
            case LineGeometry line:
                <line x1="@Number(line.Points[0].X)" y1="@Number(line.Points[0].Y)" x2="@Number(line.Points[1].X)" y2="@Number(line.Points[1].Y)" stroke="@Style.Stroke" stroke-width="@Number(Style.StrokeWidth)" stroke-opacity="@Opacity" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
                break;
            case RectangleGeometry rectangle:
                <rect x="0" y="0" width="@Number(rectangle.W)" height="@Number(rectangle.H)" fill="@Style.Fill" stroke="@Style.Stroke" stroke-width="@Number(Style.StrokeWidth)" fill-opacity="@Opacity" stroke-opacity="@Opacity" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
                break;
            case CircleGeometry circle:
                <circle cx="@Number(circle.R)" cy="@Number(circle.R)" r="@Number(circle.R)" fill="@Style.Fill" stroke="@Style.Stroke" stroke-width="@Number(Style.StrokeWidth)" fill-opacity="@Opacity" stroke-opacity="@Opacity" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
                break;
            case TriangleGeometry triangle:
                <polygon points="@Points(triangle.Points)" fill="@Style.Fill" stroke="@Style.Stroke" stroke-width="@Number(Style.StrokeWidth)" fill-opacity="@Opacity" stroke-opacity="@Opacity" @onpointerdown="HandlePointerDown" @onpointerdown:stopPropagation="Selectable" />
                break;
        }
    </g>
}

@code {
    private static readonly ShapeRegistry Registry = DefaultShapes.CreateRegistry();

    [Parameter] public FigureRow? Figure { get; set; }
    [Parameter] public ShapePlacement? PreviewPlacement { get; set; }
    [Parameter] public string? PreviewType { get; set; }
    [Parameter] public bool Selectable { get; set; }
    [Parameter] public EventCallback<PointerEventArgs> OnPointerDown { get; set; }

    private IFigureGeometry? Geometry { get; set; }
    private FigureStyle Style { get; set; } = new FigureStyle();
    private decimal X { get; set; }
    private decimal Y { get; set; }
    private decimal Rotation { get; set; }
    private bool Preview => PreviewPlacement is not null;
    private string Opacity => Number(Preview ? Style.Opacity * 0.7 : Style.Opacity);
    private string Transform => $"translate({Number(X)}, {Number(Y)}) rotate({Number(Rotation)})";

    protected override void OnParametersSet()
    {
        Geometry = null;
        Style = new FigureStyle();
        X = Y = Rotation = 0;

        if (Figure is not null && Registry.TryGet(Figure.Type, out var definition))
        {
            try
            {
                using var document = System.Text.Json.JsonDocument.Parse(Figure.GeometryJson);
                if (definition.TryParseGeometry(document.RootElement, out var geometry))
                {
                    Geometry = geometry;
                    Style = StyleGateway.Parse(Figure.StyleJson);
                    X = Figure.X;
                    Y = Figure.Y;
                    Rotation = Figure.Rotation;
                }
            }
            catch (System.Text.Json.JsonException)
            {
                // A corrupt persisted row is not rendered; database constraints and the gateway
                // normally make this unreachable, but a component must not tear down a circuit.
            }
        }
        else if (PreviewPlacement is { } placement && Registry.Contains(PreviewType))
        {
            Geometry = placement.Geometry;
            X = (decimal)placement.X;
            Y = (decimal)placement.Y;
        }
    }

    private Task HandlePointerDown(PointerEventArgs e) =>
        Selectable ? OnPointerDown.InvokeAsync(e) : Task.CompletedTask;

    private static string Number(double value) => value.ToString("0.################", CultureInfo.InvariantCulture);
    private static string Number(decimal value) => value.ToString("0.############################", CultureInfo.InvariantCulture);
    private static string Points(IReadOnlyList<LocalPoint> points) => string.Join(" ", points.Select(point => $"{Number(point.X)},{Number(point.Y)}"));
}
