@using System.Globalization
@using BlazorCanvas.Data.V11
@using BlazorCanvas.Shapes

@if (Geometry is not null)
{
    <g fill="none" pointer-events="none" transform="@Transform">
        @switch (Geometry)
        {
            case LineGeometry line:
                <line x1="@Number(line.Points[0].X)" y1="@Number(line.Points[0].Y)" x2="@Number(line.Points[1].X)" y2="@Number(line.Points[1].Y)" stroke="#FFFFFF" stroke-width="2" />
                <line x1="@Number(line.Points[0].X)" y1="@Number(line.Points[0].Y)" x2="@Number(line.Points[1].X)" y2="@Number(line.Points[1].Y)" stroke="#1D4ED8" stroke-width="1" stroke-dasharray="4 4" />
                break;
            case RectangleGeometry rectangle:
                <rect x="0" y="0" width="@Number(rectangle.W)" height="@Number(rectangle.H)" stroke="#FFFFFF" stroke-width="2" />
                <rect x="0" y="0" width="@Number(rectangle.W)" height="@Number(rectangle.H)" stroke="#1D4ED8" stroke-width="1" stroke-dasharray="4 4" />
                break;
            case CircleGeometry circle:
                <circle cx="@Number(circle.R)" cy="@Number(circle.R)" r="@Number(circle.R)" stroke="#FFFFFF" stroke-width="2" />
                <circle cx="@Number(circle.R)" cy="@Number(circle.R)" r="@Number(circle.R)" stroke="#1D4ED8" stroke-width="1" stroke-dasharray="4 4" />
                break;
            case TriangleGeometry triangle:
                <polygon points="@Points(triangle.Points)" stroke="#FFFFFF" stroke-width="2" />
                <polygon points="@Points(triangle.Points)" stroke="#1D4ED8" stroke-width="1" stroke-dasharray="4 4" />
                break;
            case Star5Geometry star:
                <polygon points="@Points(star.Points)" stroke="#FFFFFF" stroke-width="2" />
                <polygon points="@Points(star.Points)" stroke="#1D4ED8" stroke-width="1" stroke-dasharray="4 4" />
                break;
        }
    </g>
}

@code {
    private static readonly ShapeRegistry Registry = DefaultShapes.CreateRegistry();

    [Parameter, EditorRequired] public FigureRow Figure { get; set; } = null!;

    private IFigureGeometry? Geometry { get; set; }
    private string Transform { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        Geometry = null;
        Transform = string.Empty;
        if (!Registry.TryGet(Figure.Type, out var definition))
        {
            return;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(Figure.GeometryJson);
            if (definition.TryParseGeometry(document.RootElement, out var geometry))
            {
                Geometry = geometry;
                Transform = $"translate({Number(Figure.X)}, {Number(Figure.Y)}) rotate({Number(Figure.Rotation)})";
            }
        }
        catch (System.Text.Json.JsonException)
        {
            // See FigureShape: rendering must be fail-closed for corrupt persisted JSON.
        }
    }

    private static string Number(double value) => value.ToString("0.################", CultureInfo.InvariantCulture);
    private static string Number(decimal value) => value.ToString("0.############################", CultureInfo.InvariantCulture);
    private static string Points(IReadOnlyList<LocalPoint> points) => string.Join(" ", points.Select(point => $"{Number(point.X)},{Number(point.Y)}"));
}
