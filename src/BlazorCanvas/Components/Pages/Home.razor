@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using BlazorCanvas.Tools
@using BlazorCanvas.Components.Canvas
@using BlazorCanvas.Data
@using BlazorCanvas.Geometry
@inject FigureStore Figures

<PageTitle>BlazorCanvas</PageTitle>

<Toolbar @bind-Armed="armedTool" />

<div class="canvas-area">
    <svg class="@CanvasSurfaceClass" width="1280" height="720">
        @foreach (var f in figures)
        {
            <FigureShape @key="f.Id" Type="FigureTypeNames.Parse(f.Type)" Box="new Box(f.X1, f.Y1, f.X2, f.Y2)" />
        }
    </svg>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    // Read once from the signed authentication cookie's claim (D-51) - the sole source of userId.
    // No database lookup happens here; the figures query below is the page's one and only read.
    private int userId;

    // Explicit default, even though Tool.Pointer is also default(Tool): D-31 makes "the pointer
    // tool is armed on page load" a locked behavioural rule and this should read as such.
    private Tool armedTool = Tool.Pointer;

    private List<Figure> figures = new();

    // The shape-armed class drives the crosshair cursor rule in Home.razor.css. The pointer tool
    // keeps the default cursor, matching 03-UI-SPEC's Canvas & Cursor Spec.
    private string CanvasSurfaceClass => armedTool != Tool.Pointer ? "canvas-surface shape-armed" : "canvas-surface";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask!;
        userId = int.Parse(state.User.FindFirst("user_id")!.Value);
        figures = await Figures.LoadAsync(userId);
    }
}
