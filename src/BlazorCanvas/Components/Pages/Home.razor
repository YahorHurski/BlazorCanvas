@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using BlazorCanvas.Tools
@using BlazorCanvas.Components.Canvas
@using BlazorCanvas.Data.V11
@using BlazorCanvas.Geometry
@using BlazorCanvas.Shapes
@using BlazorCanvas.Sync
@inject CanvasRepository Canvases
@inject FigureRepository FigureRepository
@inject FigureInputGateway FigureGateway
@inject ShapeRegistry ShapeRegistry
@inject CanvasSyncNotifier Notifier
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>BlazorCanvas</PageTitle>

<div class="app-shell" @onpointermove="OnWrapperPointerMove" @onpointerup="OnWrapperPointerUp" @onpointerleave="OnWrapperPointerLeave">
    <Toolbar @bind-Armed="armedTool" DeleteEnabled="@(coordinator?.SelectedId is not null)" OnDelete="HandleDeleteAsync" OnDeselect="Deselect" />
    <div class="canvas-area">
        <svg @ref="canvasSurface" class="@CanvasSurfaceClass" width="@CanvasBounds.Width" height="@CanvasBounds.Height" data-preview-tool="@ToolMap.ToShapeName(armedTool)" @onpointerdown="OnPointerDown" @onpointermove="OnPointerMove" @onpointerup="OnPointerUp" @onpointerleave="OnPointerLeave">
            @if (coordinator is not null)
            {
                @foreach (var figure in coordinator.Figures)
                {
                    <FigureShape @key="figure.Id" Figure="figure" Selectable="@(armedTool == Tool.Pointer)" OnPointerDown="e => HandleFigurePointerDown(figure.Id, e)" />
                }
                @if (coordinator.SelectedId is { } selectedId)
                {
                    var selected = coordinator.Figures.FirstOrDefault(figure => figure.Id == selectedId);
                    if (selected is not null)
                    {
                        <SelectionTrace Figure="selected" />
                    }
                }
            }
            @if (preview?.IsActive == true && preview.Placement is not null)
            {
                <FigureShape PreviewPlacement="preview.Placement" PreviewType="preview.Type" Selectable="false" />
            }
        </svg>
    </div>
</div>

@if (coordinator?.ShowSaveFailedModal == true)
{
    <div class="save-failed-backdrop"></div>
    <dialog open class="save-failed-modal" role="alertdialog" aria-modal="true">
        <p>The change could not be saved. The canvas will be reloaded from the database.</p>
        <button type="button" autofocus @onclick="ReloadFromDatabaseAsync">OK</button>
    </dialog>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private CanvasInteractionCoordinator? coordinator;
    private IDisposable? subscription;
    private Tool armedTool = Tool.Pointer;
    private DrawingPreviewSession? preview;
    private ElementReference canvasSurface;
    private IJSObjectReference? previewModule;

    private string CanvasSurfaceClass => "canvas-surface"
        + (armedTool != Tool.Pointer ? " shape-armed" : string.Empty)
        + (coordinator?.IsDragging == true ? " is-dragging" : string.Empty);

    protected override async Task OnInitializedAsync()
    {
        preview = new DrawingPreviewSession(ShapeRegistry);
        var state = await AuthStateTask!;
        var ownerId = int.Parse(state.User.FindFirst("user_id")!.Value);
        var canvas = await Canvases.EnsureForOwnerAsync(ownerId);
        coordinator = new CanvasInteractionCoordinator(
            FigureGateway,
            Notifier,
            ownerId,
            canvas.Id,
            ct => FigureRepository.LoadAsync(canvas.Id, ct),
            (input, x, y, ct) => FigureRepository.InsertAsync(canvas.Id, input, x, y, ct: ct),
            (id, x, y, ct) => FigureRepository.MoveAsync(canvas.Id, id, x, y, ct),
            (id, ct) => FigureRepository.DeleteAsync(canvas.Id, id, ct));
        await coordinator.LoadAsync();
        subscription = Notifier.Subscribe(ownerId, HandleRemoteMessage);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        previewModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
        await previewModule.InvokeVoidAsync("attach", canvasSurface);
    }

    public async ValueTask DisposeAsync()
    {
        subscription?.Dispose();
        if (previewModule is null) return;

        try
        {
            await previewModule.InvokeVoidAsync("detach", canvasSurface);
            await previewModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            // The browser can close before circuit disposal; no local preview remains to clean up.
        }
    }

    private void OnPointerDown(PointerEventArgs e)
    {
        if (e.Button != 0 || coordinator is null) return;
        Deselect();
        var type = ToolMap.ToShapeName(armedTool);
        if (type is null) return;
        preview ??= new DrawingPreviewSession(ShapeRegistry);
        preview.Begin(type, ToCanvasPoint(e));
    }

    private void HandleFigurePointerDown(Guid id, PointerEventArgs e)
    {
        if (e.Button != 0 || coordinator is null) return;
        coordinator.BeginDrag(id, ToCanvasPoint(e));
    }

    private Task OnWrapperPointerMove(PointerEventArgs e) => ContinueDragAsync(e);

    private async Task ContinueDragAsync(PointerEventArgs e)
    {
        if (coordinator?.IsDragging != true) return;
        if ((e.Buttons & 1) == 0) await coordinator.CommitDragAsync();
        else coordinator.ContinueDrag(ToCanvasPoint(e));
    }

    private async Task OnWrapperPointerUp(PointerEventArgs _) { if (coordinator?.IsDragging == true) await coordinator.CommitDragAsync(); }
    private async Task OnWrapperPointerLeave(PointerEventArgs _) { if (coordinator?.IsDragging == true) await coordinator.CommitDragAsync(); }

    private async Task OnPointerMove(PointerEventArgs e)
    {
        if (coordinator?.IsDragging == true) { await ContinueDragAsync(e); return; }
        if (preview?.IsActive != true) return;
        if ((e.Buttons & 1) == 0) { await CommitDrawAsync(); return; }
        preview.Update(ToCanvasPoint(e));
    }

    private async Task OnPointerUp(PointerEventArgs _) { if (coordinator?.IsDragging == true) await coordinator.CommitDragAsync(); else if (preview?.IsActive == true) await CommitDrawAsync(); }
    private async Task OnPointerLeave(PointerEventArgs _) { if (coordinator?.IsDragging == true) await coordinator.CommitDragAsync(); else if (preview?.IsActive == true) await CommitDrawAsync(); }

    private async Task CommitDrawAsync()
    {
        var completed = preview?.Complete();
        if (coordinator is not null && completed is not null)
            await coordinator.DrawAsync(completed.Type, completed.Press, completed.Cursor);
    }

    private Task HandleDeleteAsync() => coordinator?.DeleteAsync() ?? Task.CompletedTask;
    private Task ReloadFromDatabaseAsync() => coordinator?.ReloadAsync() ?? Task.CompletedTask;
    private void Deselect() => coordinator?.Deselect();

    private void HandleRemoteMessage(SyncMessage message)
    {
        var delivery = coordinator?.TryAuthorizeRemoteDelivery(message);
        if (delivery is null) return;

        _ = InvokeAsync(() =>
        {
            try { coordinator?.ApplyAuthorizedRemoteDelivery(delivery); StateHasChanged(); }
            catch (ObjectDisposedException) { }
        });
    }

    private static CanvasPoint ToCanvasPoint(PointerEventArgs e)
    {
        var point = CanvasCoordinates.FromPage(e.PageX, e.PageY);
        return new CanvasPoint(point.X, point.Y);
    }
}
